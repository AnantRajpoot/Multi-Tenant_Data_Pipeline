{
  "name": "MinIO Local Development Pipeline",
  "description": "Read from local MinIO instance (useful for development/testing)",
  "source": {
    "type": "s3",
    "config": {
      "endpoint": "http://localhost:9000",
      "bucket": "test-bucket",
      "key": "dev-data/sample.csv",
      "access_key": "minioadmin",
      "secret_key": "minioadmin",
      "format": "csv"
    }
  },
  "transformations": [
    {
      "type": "map",
      "config": {
        "mappings": {
          "name": "customer_name",
          "email": "customer_email",
          "amount": "purchase_amount"
        }
      }
    }
  ],
  "destination": {
    "type": "csv",
    "config": {
      "file_path": "./output/minio_data.csv",
      "include_header": true
    }
  }
}
