{
  "pipelineId": "s3-csv-test-pipeline",
  "pipelineName": "S3 CSV Test Pipeline",
  "tenantId": "demo-tenant",
  "source": {
    "type": "s3",
    "config": {
      "endpoint": "https://s3.amazonaws.com",
      "bucket": "anant858328-bucket",
      "key": "test-data.csv",
      "access_key": "${S3_ACCESS_KEY}",
      "secret_key": "${S3_SECRET_KEY}",
      "format": "csv"
    }
  },
  "transformations": [],
  "destination": {
    "type": "json",
    "config": {
      "path": "output.json"
    }
  }
}
